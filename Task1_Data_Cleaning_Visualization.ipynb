   "source": [
    "#  Task 1: Data Cleaning & Visualization\n",
    "**Dataset:** Titanic (built-in via Seaborn)\n",
    "\n",
    "**Objectives:**\n",
    "- Handle missing values, outliers, and duplicates\n",
    "- Use Pandas, Matplotlib, Seaborn\n",
    "- Create visual reports of key findings"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📦 Step 1: Install & Import Libraries"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Plot style\n",
    "sns.set_theme(style='whitegrid', palette='muted')\n",
    "plt.rcParams['figure.figsize'] = (10, 6)\n",
    "\n",
    "print(' Libraries imported successfully!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "##  Step 2: Load Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load Titanic dataset directly from Seaborn (no download needed!)\n",
    "df = sns.load_dataset('titanic')\n",
    "\n",
    "print(f'Shape: {df.shape}')\n",
    "print(f'Columns: {list(df.columns)}')\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🔍 Step 3: Initial Exploration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== Dataset Info ===')\n",
    "df.info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== Statistical Summary ===')\n",
    "df.describe()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Missing values analysis\n",
    "missing = df.isnull().sum()\n",
    "missing_pct = (df.isnull().sum() / len(df)) * 100\n",
    "missing_df = pd.DataFrame({'Missing Count': missing, 'Missing %': missing_pct})\n",
    "missing_df = missing_df[missing_df['Missing Count'] > 0].sort_values('Missing %', ascending=False)\n",
    "\n",
    "print('=== Missing Values ===')\n",
    "print(missing_df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize missing values\n",
    "plt.figure(figsize=(10, 5))\n",
    "sns.heatmap(df.isnull(), cbar=False, cmap='viridis', yticklabels=False)\n",
    "plt.title('Missing Values Heatmap (Yellow = Missing)', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧹 Step 4: Data Cleaning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df_clean = df.copy()\n",
    "\n",
    "# --- 1. Handle Missing Values ---\n",
    "\n",
    "# Age: fill with median (robust to outliers)\n",
    "age_before = df_clean['age'].copy()\n",
    "df_clean['age'].fillna(df_clean['age'].median(), inplace=True)\n",
    "print(f'Age: {age_before.isnull().sum()} missing values filled with median ({df[\"age\"].median():.1f})')\n",
    "\n",
    "# Embarked: fill with mode\n",
    "df_clean['embarked'].fillna(df_clean['embarked'].mode()[0], inplace=True)\n",
    "print(f'Embarked: filled with mode ({df[\"embarked\"].mode()[0]})')\n",
    "\n",
    "# Deck/Cabin: too many missing (77%) — drop the column\n",
    "df_clean.drop(columns=['deck'], inplace=True)\n",
    "print('Deck column dropped (77% missing)')\n",
    "\n",
    "# --- 2. Remove Duplicates ---\n",
    "dups = df_clean.duplicated().sum()\n",
    "df_clean.drop_duplicates(inplace=True)\n",
    "print(f'\\nDuplicates removed: {dups}')\n",
    "\n",
    "# --- 3. Fix Data Types ---\n",
    "df_clean['survived'] = df_clean['survived'].astype('category')\n",
    "df_clean['pclass'] = df_clean['pclass'].astype('category')\n",
    "print('\\nData types fixed: survived, pclass → category')\n",
    "\n",
    "print(f'\\n Cleaned shape: {df_clean.shape}')\n",
    "print(f'Remaining missing values: {df_clean.isnull().sum().sum()}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- 4. Outlier Detection & Treatment for Fare ---\n",
    "Q1 = df_clean['fare'].quantile(0.25)\n",
    "Q3 = df_clean['fare'].quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR\n",
    "\n",
    "outliers = df_clean[(df_clean['fare'] < lower) | (df_clean['fare'] > upper)]\n",
    "print(f'Fare outliers detected: {len(outliers)}')\n",
    "\n",
    "# Cap outliers instead of dropping\n",
    "df_clean['fare_capped'] = df_clean['fare'].clip(lower=lower, upper=upper)\n",
    "print(f'Outliers capped at upper bound: {upper:.2f}')\n",
    "\n",
    "# Visualize before/after\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "axes[0].boxplot(df_clean['fare'].dropna())\n",
    "axes[0].set_title('Fare — Before Capping', fontsize=12, fontweight='bold')\n",
    "axes[0].set_ylabel('Fare (£)')\n",
    "\n",
    "axes[1].boxplot(df_clean['fare_capped'].dropna())\n",
    "axes[1].set_title('Fare — After Capping', fontsize=12, fontweight='bold')\n",
    "axes[1].set_ylabel('Fare (£)')\n",
    "\n",
    "plt.suptitle('Outlier Treatment on Fare Column', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📊 Step 5: Visualizations"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Viz 1: Age Distribution Before vs After Imputation ---\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].hist(df['age'].dropna(), bins=30, color='#e74c3c', edgecolor='black', alpha=0.8)\n",
    "axes[0].set_title('Age Distribution — Before Imputation', fontsize=12, fontweight='bold')\n",
    "axes[0].set_xlabel('Age')\n",
    "axes[0].set_ylabel('Count')\n",
    "axes[0].axvline(df['age'].median(), color='navy', linestyle='--', label=f'Median: {df[\"age\"].median():.1f}')\n",
    "axes[0].legend()\n",
    "\n",
    "axes[1].hist(df_clean['age'], bins=30, color='#2ecc71', edgecolor='black', alpha=0.8)\n",
    "axes[1].set_title('Age Distribution — After Imputation', fontsize=12, fontweight='bold')\n",
    "axes[1].set_xlabel('Age')\n",
    "axes[1].set_ylabel('Count')\n",
    "axes[1].axvline(df_clean['age'].median(), color='navy', linestyle='--', label=f'Median: {df_clean[\"age\"].median():.1f}')\n",
    "axes[1].legend()\n",
    "\n",
    "plt.suptitle('Age Distribution: Before vs After Imputation', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Viz 2: Survival Rate by Gender ---\n",
    "survival_gender = df_clean.groupby('sex')['survived'].value_counts(normalize=True).unstack()\n",
    "survival_gender.columns = ['Did Not Survive', 'Survived']\n",
    "\n",
    "survival_gender.plot(kind='bar', stacked=True, color=['#e74c3c', '#2ecc71'],\n",
    "                     figsize=(8, 5), edgecolor='black')\n",
    "plt.title('Survival Rate by Gender', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Gender')\n",
    "plt.ylabel('Proportion')\n",
    "plt.xticks(rotation=0)\n",
    "plt.legend(loc='upper right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Viz 3: Survival Rate by Passenger Class ---\n",
    "survival_class = df_clean.groupby(df_clean['pclass'].astype(str))['survived'].value_counts(normalize=True).unstack()\n",
    "survival_class.columns = ['Did Not Survive', 'Survived']\n",
    "\n",
    "survival_class.plot(kind='bar', stacked=True, color=['#e74c3c', '#3498db'],\n",
    "                    figsize=(8, 5), edgecolor='black')\n",
    "plt.title('Survival Rate by Passenger Class', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Passenger Class (1=First, 2=Second, 3=Third)')\n",
    "plt.ylabel('Proportion')\n",
    "plt.xticks(rotation=0)\n",
    "plt.legend(loc='upper right')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Viz 4: Correlation Heatmap ---\n",
    "numeric_cols = df_clean.select_dtypes(include=[np.number]).drop(columns=['fare_capped'])\n",
    "corr = numeric_cols.corr()\n",
    "\n",
    "plt.figure(figsize=(10, 7))\n",
    "mask = np.triu(np.ones_like(corr, dtype=bool))\n",
    "sns.heatmap(corr, annot=True, fmt='.2f', cmap='coolwarm',\n",
    "            mask=mask, linewidths=0.5, vmin=-1, vmax=1)\n",
    "plt.title('Correlation Heatmap of Numeric Features', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Viz 5: Age vs Fare colored by Survival ---\n",
    "survived_map = {0: 'Did Not Survive', 1: 'Survived'}\n",
    "df_plot = df_clean.copy()\n",
    "df_plot['survived_label'] = df_plot['survived'].astype(int).map(survived_map)\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "for label, color in zip(['Survived', 'Did Not Survive'], ['#2ecc71', '#e74c3c']):\n",
    "    subset = df_plot[df_plot['survived_label'] == label]\n",
    "    plt.scatter(subset['age'], subset['fare_capped'], alpha=0.5, label=label, color=color, s=40)\n",
    "\n",
    "plt.title('Age vs Fare by Survival Status', fontsize=14, fontweight='bold')\n",
    "plt.xlabel('Age')\n",
    "plt.ylabel('Fare (Capped)')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 📝 Step 6: Key Findings Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "survival_rate = df_clean['survived'].astype(int).mean() * 100\n",
    "female_survival = df_clean[df_clean['sex'] == 'female']['survived'].astype(int).mean() * 100\n",
    "male_survival = df_clean[df_clean['sex'] == 'male']['survived'].astype(int).mean() * 100\n",
    "class1_survival = df_clean[df_clean['pclass'] == 1]['survived'].astype(int).mean() * 100\n",
    "class3_survival = df_clean[df_clean['pclass'] == 3]['survived'].astype(int).mean() * 100\n",
    "\n",
    "print('='*50)\n",
    "print('           KEY FINDINGS SUMMARY')\n",
    "print('='*50)\n",
    "print(f'\\n Overall Survival Rate     : {survival_rate:.1f}%')\n",
    "print(f' Female Survival Rate      : {female_survival:.1f}%')\n",
    "print(f' Male Survival Rate        : {male_survival:.1f}%')\n",
    "print(f' 1st Class Survival Rate   : {class1_survival:.1f}%')\n",
    "print(f' 3rd Class Survival Rate   : {class3_survival:.1f}%')\n",
    "print(f' Rows after cleaning       : {df_clean.shape[0]}')\n",
    "print(f' Missing values remaining  : {df_clean.isnull().sum().sum()}')\n",
    
   ]
  }
 ]
}
